# ============================================
# AI Financial Intelligence System — Config
# Copy this to .env and fill in your values
# ============================================

# --- Ollama / Llama 3 ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- News APIs (optional — uses yfinance news if blank) ---
NEWS_API_KEY=
FINNHUB_API_KEY=
NEWS_CACHE_TTL=15
NEWS_MAX_ARTICLES=20

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Feature Flags ---
ENABLE_NEWS=true
ENABLE_SENTIMENT=true
ENABLE_AI_REASONING=true
ENABLE_RAG=true
ENABLE_EXPLAINABILITY=true
